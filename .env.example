# Single-account mode
QQBOT_APP_ID=your_app_id
QQBOT_CLIENT_SECRET=your_client_secret

# Multi-account mode example
# QQBOT_ACCOUNTS_JSON=[{"id":"default","name":"Default","appId":"111","clientSecret":"secret-1"},{"id":"bot2","name":"Bot 2","appId":"222","clientSecret":"secret-2","allowFrom":["u_openid_1","u_openid_2"]}]

HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent
HERMES_CONVERSATION_PREFIX=qqbot
# HERMES_SYSTEM_PROMPT=You are a helpful assistant.

QQBOT_ENABLE_C2C=true
QQBOT_ENABLE_GROUP_AT=true
QQBOT_ENABLE_GUILD_AT=true
QQBOT_ENABLE_GUILD_DM=true
QQBOT_ALLOW_FROM=*

QQBOT_TEXT_CHUNK_LIMIT=4500
QQBOT_DEDUPE_TTL_MS=600000
QQBOT_REQUEST_TIMEOUT_MS=300000

QQBOT_DATA_DIR=.data
QQBOT_DOWNLOAD_ATTACHMENTS=true
QQBOT_MAX_DOWNLOAD_BYTES=20971520

LOG_LEVEL=info
